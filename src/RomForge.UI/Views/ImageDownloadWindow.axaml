<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RomForge.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="RomForge.UI.Views.ImageDownloadWindow"
        x:DataType="vm:ImageDownloadWindowVM"
        Title="Downloading Images"
        Width="520"
        Height="360"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16" RowDefinitions="*,Auto,Auto">

        <!-- Scrolling log of every image as it is fetched -->
        <TextBox Grid.Row="0"
                 Text="{Binding LogText}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Menlo,Consolas,monospace"
                 FontSize="12"
                 VerticalContentAlignment="Top"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Overall progress -->
        <ProgressBar Grid.Row="1"
                     Margin="0,12,0,0"
                     Minimum="0"
                     Maximum="{Binding Total}"
                     Value="{Binding Current}"
                     IsIndeterminate="{Binding IsIndeterminate}"
                     Height="12"/>

        <!-- Count + Close/Cancel -->
        <Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding CountText}"
                       VerticalAlignment="Center"
                       FontSize="12"/>
            <Button Grid.Column="1"
                    Content="{Binding CloseButtonText}"
                    Command="{Binding CloseOrCancelCommand}"
                    Padding="16,4"/>
        </Grid>

    </Grid>
</Window>